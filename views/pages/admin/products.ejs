<%- include('../../partials/header') %>
<div class="page-header"><h1>Kelola Produk</h1><p>Tambah, edit, dan kelola produk marketplace</p></div>
<section class="section-sm"><div class="container"><div class="dashboard-layout">
<%- include('../../partials/admin-sidebar') %>
<div>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
<h3>Daftar Produk (<%= products.length %>)</h3>
<button class="btn btn-primary" onclick="openProductModal(null)"><i class="fas fa-plus"></i> Tambah Produk</button>
</div>
<div class="card"><div class="table-wrap"><table>
<thead><tr><th>Gambar</th><th>Nama Produk</th><th>Kategori</th><th>Harga</th><th>Stok</th><th>Terjual</th><th>Status</th><th>Aksi</th></tr></thead>
<tbody>
<% products.forEach(p=>{ %>
<tr>
<td><% if(p.image){%><img src="/images/products/<%=p.image%>" style="width:48px;height:48px;object-fit:cover;border-radius:var(--r-sm)"><% }else{ %><div style="width:48px;height:48px;background:var(--c-bg2);border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;color:var(--c-text3)">🌿</div><% } %></td>
<td style="max-width:200px"><strong style="font-size:13px"><%= p.name %></strong><% if(p.eco_label){%><br><span class="badge-eco" style="font-size:10px"><%=p.eco_label%></span><%}%></td>
<td style="font-size:13px"><%= p.cat_name||'—' %></td>
<td style="font-weight:600;white-space:nowrap;font-size:13px">Rp <%= Number(p.price).toLocaleString('id-ID') %></td>
<td style="font-size:13px"><span style="color:<%= p.stock<10?'var(--c-red)':'var(--c-text)' %>"><%= p.stock %></span></td>
<td style="font-size:13px"><%= p.sold_count %></td>
<td><span class="status <%=p.is_active?'status-confirmed':'status-cancelled'%>"><%=p.is_active?'Aktif':'Nonaktif'%></span></td>
<td style="white-space:nowrap">
<button class="btn btn-outline btn-sm" onclick='openProductModal(<%- JSON.stringify({id:p.id,name:p.name,description:p.description,price:p.price,stock:p.stock,eco_label:p.eco_label||"",is_featured:p.is_featured,is_active:p.is_active}) %>)'>Edit</button>
<form action="/admin/products/<%= p.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Nonaktifkan produk ini?')"><button class="btn btn-danger btn-sm" type="submit">Nonaktif</button></form>
</td>
</tr>
<% }) %>
</tbody>
</table></div></div>
</div>
</div></div></section>

<!-- Product Modal -->
<div class="modal-overlay" id="productModal">
<div class="modal" style="max-width:640px">
<div class="modal-header"><h3 class="modal-title">Produk</h3><button class="modal-close" onclick="closeModal('productModal')"><i class="fas fa-times"></i></button></div>
<form action="/admin/products" method="POST" enctype="multipart/form-data">
<div class="grid-2">
<div class="form-group"><label class="form-label">Nama Produk *</label><input name="name" class="form-control" required></div>
<div class="form-group"><label class="form-label">Kategori</label><select name="category_id" class="form-control"><option value="">— Pilih —</option><% categories.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select></div>
</div>
<div class="form-group"><label class="form-label">Deskripsi</label><textarea name="description" class="form-control" rows="3"></textarea></div>
<div class="grid-2">
<div class="form-group"><label class="form-label">Harga (Rp) *</label><input name="price" type="number" class="form-control" required></div>
<div class="form-group"><label class="form-label">Stok *</label><input name="stock" type="number" class="form-control" required></div>
</div>
<div class="grid-2">
<div class="form-group"><label class="form-label">Label Eco</label><input name="eco_label" class="form-control" placeholder="Contoh: Organic, Recycled"></div>
<div class="form-group"><label class="form-label">Gambar Produk</label><input name="image" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp"></div>
</div>
<div style="display:flex;gap:20px;margin-bottom:20px">
<label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer"><input type="checkbox" name="is_featured" value="1" style="accent-color:var(--c-primary)"> Produk Unggulan</label>
<label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer"><input type="checkbox" name="is_active" value="1" checked style="accent-color:var(--c-primary)"> Aktif</label>
</div>
<div style="display:flex;gap:12px;justify-content:flex-end">
<button type="button" class="btn btn-ghost" onclick="closeModal('productModal')">Batal</button>
<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button>
</div>
</form>
</div>
</div>
<%- include('../../partials/footer') %>
