<%- include('../../partials/header') %>
<div class="page-header"><h1>Detail Pesanan</h1><p><%= order.order_code %></p><div class="breadcrumb"><a href="/">Home</a><span>›</span><a href="/user/orders">Pesanan</a><span>›</span><span>Detail</span></div></div>
<section class="section-sm"><div class="container"><div class="dashboard-layout">
<%- include('../../partials/sidebar') %>
<div>
<div class="card" style="margin-bottom:20px"><div class="card-body">
<div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px">
<div><h3 style="margin-bottom:4px"><%= order.order_code %></h3><p style="font-size:13px;color:var(--c-text3)">Dipesan: <%= new Date(order.created_at).toLocaleDateString('id-ID',{dateStyle:'long'}) %></p></div>
<div style="display:flex;gap:8px;flex-wrap:wrap">
<span class="status status-<%= order.payment_status %>">Bayar: <%= {pending:'Belum',paid:'Lunas',failed:'Gagal'}[order.payment_status] %></span>
<span class="status status-<%= order.order_status %>"><%= {pending:'Pending',processing:'Diproses',shipped:'Dikirim',completed:'Selesai',cancelled:'Dibatalkan'}[order.order_status] %></span>
</div>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px">
<div><h5 style="margin-bottom:10px;color:var(--c-text3);font-size:12px;text-transform:uppercase">Alamat Pengiriman</h5>
<p style="font-weight:600"><%= order.shipping_name %></p>
<p style="font-size:14px;color:var(--c-text2)"><%= order.shipping_phone %></p>
<p style="font-size:14px;color:var(--c-text2)"><%= order.shipping_address %></p>
</div>
<div><h5 style="margin-bottom:10px;color:var(--c-text3);font-size:12px;text-transform:uppercase">Pembayaran</h5>
<p style="font-weight:600"><%= order.payment_method==='bank_transfer'?'Transfer Bank':'QRIS' %></p>
<p style="font-size:14px;color:var(--c-text2)">Subtotal: Rp <%= Number(order.total_amount).toLocaleString('id-ID') %></p>
<p style="font-size:14px;color:var(--c-text2)">Ongkir: <%= order.shipping_fee>0?'Rp '+Number(order.shipping_fee).toLocaleString('id-ID'):'GRATIS' %></p>
<p style="font-size:16px;font-weight:700;color:var(--c-primary)">Total: Rp <%= Number(order.grand_total).toLocaleString('id-ID') %></p>
</div>
</div>
<h4 style="margin-bottom:16px">Item Pesanan</h4>
<% items.forEach(item=>{ %>
<div style="display:flex;gap:12px;padding:14px 0;border-bottom:1px solid var(--c-border);align-items:center">
<% if (item.image) { %><img src="/images/products/<%= item.image %>" style="width:60px;height:60px;object-fit:cover;border-radius:var(--r-md)"><% } else { %><div style="width:60px;height:60px;background:var(--c-bg2);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;color:var(--c-text3);font-size:24px">🌿</div><% } %>
<div style="flex:1"><a href="/shop/<%= item.slug %>" style="font-weight:600;font-size:14px"><%= item.name %></a><div style="font-size:13px;color:var(--c-text3)">Rp <%= Number(item.price).toLocaleString('id-ID') %> × <%= item.qty %></div></div>
<div style="font-weight:700;color:var(--c-primary)">Rp <%= Number(item.subtotal).toLocaleString('id-ID') %></div>
</div>
<% }) %>
</div></div>
<% if (order.payment_status === 'pending') { %>
<div class="card"><div class="card-body" style="text-align:center">
<p style="color:var(--c-text3);margin-bottom:16px">Pesanan ini menunggu pembayaran Anda</p>
<a href="/shop/payment/<%= order.id %>" class="btn btn-primary btn-lg"><i class="fas fa-credit-card"></i> Bayar Sekarang</a>
</div></div>
<% } %>
<% if (order.payment_proof) { %>
<div class="card" style="margin-top:20px"><div class="card-body"><h4 style="margin-bottom:12px">Bukti Pembayaran</h4>
<% if (['.jpg','.jpeg','.png'].some(e=>order.payment_proof.endsWith(e))) { %>
<img src="/uploads/proofs/<%= order.payment_proof %>" style="max-width:300px;border-radius:var(--r-md)">
<% } else { %><p style="font-size:14px;color:var(--c-text3)"><i class="fas fa-file-pdf"></i> <%= order.payment_proof %></p><% } %>
</div></div>
<% } %>
</div></div></div></section>
<%- include('../../partials/footer') %>
