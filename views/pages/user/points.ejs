<%- include('../../partials/header') %>
<div class="page-header"><h1>Poin & Reward</h1><div class="breadcrumb"><a href="/">Home</a><span>›</span><a href="/user/dashboard">Dashboard</a><span>›</span><span>Poin</span></div></div>
<section class="section-sm"><div class="container"><div class="dashboard-layout">
<%- include('../../partials/sidebar') %>
<div>
<div class="points-hero" style="margin-bottom:24px">
<p style="color:rgba(255,255,255,.7);margin-bottom:8px">Total Poin Anda</p>
<div class="points-value"><%= points %></div>
<p style="color:var(--c-accent);font-size:14px;margin-top:8px"><i class="fas fa-star"></i> Poin</p>
<div style="margin-top:20px;display:flex;justify-content:center;gap:24px">
<div style="text-align:center"><span style="display:block;font-size:22px;font-weight:700;color:var(--c-accent)"><%= Math.floor(points/100) %></span><span style="font-size:12px;color:rgba(255,255,255,.7)">Voucher Tersedia</span></div>
<div style="text-align:center"><span style="display:block;font-size:22px;font-weight:700;color:var(--c-accent)"><%= history.filter(h=>h.type==='earn').length %></span><span style="font-size:12px;color:rgba(255,255,255,.7)">Total Earn</span></div>
</div>
</div>

<div class="card" style="margin-bottom:24px"><div class="card-body">
<h4 style="margin-bottom:16px">Cara Mendapatkan Poin</h4>
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
<% [{icon:'♻️',title:'Daur Ulang',pts:'+50 poin',desc:'Per pengajuan daur ulang'},{icon:'🛒',title:'Belanja',pts:'+10 poin',desc:'Per Rp 10.000 belanja'},{icon:'⭐',title:'Review',pts:'+5 poin',desc:'Per ulasan produk'}].forEach(r=>{ %>
<div style="background:var(--c-bg2);border-radius:var(--r-lg);padding:16px;text-align:center">
<div style="font-size:28px;margin-bottom:8px"><%= r.icon %></div>
<div style="font-weight:700;color:var(--c-primary);font-size:15px"><%= r.pts %></div>
<div style="font-size:12px;font-weight:600;margin-bottom:4px"><%= r.title %></div>
<div style="font-size:11px;color:var(--c-text3)"><%= r.desc %></div>
</div>
<% }) %>
</div>
<div style="margin-top:16px;padding:12px;background:rgba(200,232,122,.15);border-radius:var(--r-md);border-left:3px solid var(--c-accent-d)">
<p style="font-size:13px;color:var(--c-text2)"><i class="fas fa-info-circle" style="color:var(--c-accent-d)"></i> <strong>100 poin</strong> = <strong>Rp 10.000</strong> diskon belanja. Hubungi kami untuk penukaran poin.</p>
</div>
</div></div>

<div class="card"><div class="card-body">
<h4 style="margin-bottom:16px">Riwayat Poin</h4>
<% if (!history.length) { %>
<p style="color:var(--c-text3);text-align:center;padding:24px 0">Belum ada riwayat poin</p>
<% } else { history.forEach(h=>{ %>
<div class="points-history-item">
<div><p style="font-size:14px;font-weight:500"><%= h.description %></p><p style="font-size:12px;color:var(--c-text3)"><%= new Date(h.created_at).toLocaleDateString('id-ID',{dateStyle:'long'}) %></p></div>
<span class="<%= h.type==='earn'?'points-earn':'points-redeem' %>"><%= h.type==='earn'?'+':'-' %><%= h.points %> poin</span>
</div>
<% }) } %>
</div></div>
</div></div></div></section>
<%- include('../../partials/footer') %>
