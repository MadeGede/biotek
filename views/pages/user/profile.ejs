<%- include('../../partials/header') %>
<div class="page-header"><h1>Profil Saya</h1><div class="breadcrumb"><a href="/">Home</a><span>›</span><a href="/user/dashboard">Dashboard</a><span>›</span><span>Profil</span></div></div>
<section class="section-sm"><div class="container"><div class="dashboard-layout">
<%- include('../../partials/sidebar') %>
<div>
<div class="card"><div class="card-body" style="padding:32px">
<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid var(--c-border)">
<div class="sidebar-avatar" style="width:80px;height:80px;font-size:32px"><%= userData.name.charAt(0).toUpperCase() %></div>
<div>
<h3><%= userData.name %></h3>
<p style="color:var(--c-text3);font-size:14px"><%= userData.email %></p>
<p style="font-size:13px;margin-top:4px">Bergabung: <%= new Date(userData.created_at).toLocaleDateString('id-ID',{dateStyle:'long'}) %></p>
<div class="points-badge-sidebar" style="margin-top:8px"><i class="fas fa-star"></i> <%= userData.points %> Poin</div>
</div>
</div>
<h4 style="margin-bottom:20px">Edit Profil</h4>
<form action="/user/profile" method="POST">
<div class="grid-2">
<div class="form-group"><label class="form-label">Nama Lengkap</label><input name="name" class="form-control" value="<%= userData.name %>" required></div>
<div class="form-group"><label class="form-label">Email</label><input class="form-control" value="<%= userData.email %>" disabled style="opacity:.6;cursor:not-allowed"></div>
</div>
<div class="form-group"><label class="form-label">No. HP</label><input name="phone" class="form-control" value="<%= userData.phone||'' %>" placeholder="08xxxxxxxxxx"></div>
<div class="form-group"><label class="form-label">Alamat</label><textarea name="address" class="form-control" rows="3" placeholder="Alamat lengkap Anda"><%= userData.address||'' %></textarea></div>
<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan Perubahan</button>
</form>
</div></div>
<div class="card" style="margin-top:20px"><div class="card-body">
<h4 style="margin-bottom:16px"><i class="fas fa-shield-alt" style="color:var(--c-primary-l)"></i> Keamanan Akun</h4>
<p style="font-size:14px;color:var(--c-text3);margin-bottom:16px">Untuk mengubah password, silakan hubungi tim support kami.</p>
<div style="display:flex;gap:12px;flex-wrap:wrap">
<a href="mailto:support@bioteknasional.id" class="btn btn-outline btn-sm"><i class="fas fa-envelope"></i> Hubungi Support</a>
</div>
</div></div>
</div></div></div></section>
<%- include('../../partials/footer') %>
