<%- include('../../partials/header') %>
<div class="page-header"><h1>Checkout</h1><div class="breadcrumb"><a href="/">Home</a><span>›</span><a href="/shop/cart">Keranjang</a><span>›</span><span>Checkout</span></div></div>
<section class="section-sm"><div class="container">
<div class="cart-layout">
<div>
<div class="card" style="margin-bottom:20px"><div class="card-body">
<h3 style="margin-bottom:20px"><i class="fas fa-map-marker-alt" style="color:var(--c-primary-l)"></i> Alamat Pengiriman</h3>
<form action="/shop/checkout" method="POST" id="checkoutForm">
<div class="grid-2">
<div class="form-group"><label class="form-label">Nama Penerima *</label><input name="shipping_name" class="form-control" value="<%= user?.name||'' %>" required></div>
<div class="form-group"><label class="form-label">No. HP Penerima *</label><input name="shipping_phone" class="form-control" placeholder="08xxxxxxxxxx" required></div>
</div>
<div class="form-group"><label class="form-label">Alamat Lengkap *</label><textarea name="shipping_address" class="form-control" rows="3" placeholder="Jl. Nama Jalan No. X, RT/RW, Kelurahan, Kecamatan, Kota, Kode Pos" required></textarea></div>
<div class="form-group"><label class="form-label">Catatan (Opsional)</label><input name="notes" class="form-control" placeholder="Instruksi khusus untuk pengiriman..."></div>

<h3 style="margin:24px 0 20px"><i class="fas fa-credit-card" style="color:var(--c-primary-l)"></i> Metode Pembayaran</h3>
<div class="payment-methods">
<label class="payment-option selected" id="opt-bank" onclick="selectPayment('bank_transfer',this)">
<input type="radio" name="payment_method" value="bank_transfer" checked>
<div class="payment-option-icon">🏦</div>
<h4>Transfer Bank</h4>
<p>BRI, BCA, Mandiri, BNI</p>
</label>
<label class="payment-option" id="opt-qris" onclick="selectPayment('qris',this)">
<input type="radio" name="payment_method" value="qris">
<div class="payment-option-icon">📱</div>
<h4>QRIS</h4>
<p>GoPay, OVO, DANA, ShopeePay</p>
</label>
</div>

<div id="bank-detail" class="bank-info">
<p style="font-size:13px;color:var(--c-text3);margin-bottom:12px">Transfer ke salah satu rekening berikut:</p>
<div class="bank-row"><span><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/6/68/LOGO_BRI.png/240px-LOGO_BRI.png" height="16" alt="BRI"> BRI</span><div><strong>0895 0189 2345 6789</strong><button type="button" class="copy-btn" onclick="copyText('0895018923456789')">Salin</button></div></div>
<div class="bank-row"><span>BCA</span><div><strong>8877 665 544</strong><button type="button" class="copy-btn" onclick="copyText('8877665544')">Salin</button></div></div>
<div class="bank-row"><span>Mandiri</span><div><strong>1400 0123 4567 890</strong><button type="button" class="copy-btn" onclick="copyText('14000123456789')">Salin</button></div></div>
<div class="bank-row" style="margin-top:12px;background:rgba(30,86,49,.08);padding:8px;border-radius:6px"><span>a.n.</span><strong>PT BioTeknologi Nasional</strong></div>
</div>

<div id="qris-detail" class="qris-box" style="display:none">
<div class="qris-img"><i class="fas fa-qrcode"></i></div>
<p style="font-size:13px;color:var(--c-text3)">Scan QR Code di atas atau gunakan fitur QRIS di aplikasi dompet digital Anda</p>
</div>

<div style="margin-top:20px;text-align:right">
<button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-lock"></i> Buat Pesanan</button>
</div>
</form>
</div></div>
</div>
<div class="order-summary">
<h3 style="margin-bottom:20px">Ringkasan Pesanan</h3>
<% cart.forEach(item=>{ %>
<div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;border-bottom:1px solid var(--c-border)">
<span><%= item.name %> ×<%= item.qty %></span>
<span>Rp <%= Number(item.price*item.qty).toLocaleString('id-ID') %></span>
</div>
<% }) %>
<div class="summary-row" style="margin-top:8px"><span>Subtotal</span><span>Rp <%= Number(total).toLocaleString('id-ID') %></span></div>
<div class="summary-row"><span>Ongkir</span><span><%= shipping===0?'GRATIS':'Rp '+Number(shipping).toLocaleString('id-ID') %></span></div>
<div class="summary-total"><span>Total Bayar</span><span class="price">Rp <%= Number(grandTotal).toLocaleString('id-ID') %></span></div>
<div style="margin-top:16px;padding:12px;background:var(--c-bg2);border-radius:var(--r-md);font-size:12px;color:var(--c-text3)">
<p><i class="fas fa-info-circle" style="color:var(--c-primary-l)"></i> Setelah checkout, unggah bukti pembayaran di halaman pesanan Anda.</p>
</div>
</div>
</div></div></section>
<script>
function selectPayment(method,el){document.querySelectorAll('.payment-option').forEach(o=>o.classList.remove('selected'));el.classList.add('selected');el.querySelector('input').checked=true;document.getElementById('bank-detail').style.display=method==='bank_transfer'?'block':'none';document.getElementById('qris-detail').style.display=method==='qris'?'block':'none';}
function copyText(text){navigator.clipboard.writeText(text).then(()=>showToast('Nomor rekening disalin!'));}
</script>
<%- include('../../partials/footer') %>
