<%- include('../../partials/header') %>
<div class="page-header"><h1>Pembayaran</h1><p>Kode: <%= order.order_code %></p><div class="breadcrumb"><a href="/">Home</a><span>›</span><a href="/user/orders">Pesanan</a><span>›</span><span>Pembayaran</span></div></div>
<section class="section-sm"><div class="container" style="max-width:700px">
<% if (order.payment_status === 'paid') { %>
<div style="text-align:center;padding:60px 24px"><div style="font-size:80px;margin-bottom:20px">✅</div><h2 style="color:var(--c-primary);margin-bottom:12px">Pembayaran Dikonfirmasi!</h2><p style="color:var(--c-text3);margin-bottom:32px">Pesanan Anda sedang diproses dan akan segera dikirimkan.</p><a href="/user/orders/<%= order.id %>" class="btn btn-primary btn-lg"><i class="fas fa-box"></i> Lihat Detail Pesanan</a></div>
<% } else { %>
<div class="card" style="margin-bottom:24px"><div class="card-body">
<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
<div><h3>Detail Pesanan</h3><p style="font-size:13px;color:var(--c-text3)">Kode: <strong><%= order.order_code %></strong></p></div>
<span class="status status-pending">Menunggu Pembayaran</span>
</div>
<div style="background:var(--c-bg2);border-radius:var(--r-md);padding:16px;margin-bottom:20px">
<div class="bank-row"><span>Total Pembayaran:</span><strong style="font-size:20px;color:var(--c-primary);font-family:var(--font-display)">Rp <%= Number(order.grand_total).toLocaleString('id-ID') %></strong></div>
<div class="bank-row"><span>Metode:</span><strong><%= order.payment_method==='bank_transfer'?'Transfer Bank':'QRIS' %></strong></div>
<div class="bank-row"><span>Batas Bayar:</span><strong style="color:var(--c-red)" id="countdown">24:00:00</strong></div>
</div>

<% if (order.payment_method === 'bank_transfer') { %>
<div class="bank-info">
<p style="font-weight:600;margin-bottom:12px">Transfer ke salah satu rekening ini:</p>
<div class="bank-row"><span>🏦 BRI</span><div><strong>0895 0189 2345 6789</strong><button type="button" class="copy-btn" onclick="copyText('0895018923456789')">Salin</button></div></div>
<div class="bank-row"><span>🏦 BCA</span><div><strong>8877 665 544</strong><button type="button" class="copy-btn" onclick="copyText('8877665544')">Salin</button></div></div>
<div class="bank-row"><span>🏦 Mandiri</span><div><strong>1400 0123 4567</strong><button type="button" class="copy-btn" onclick="copyText('14000123456789')">Salin</button></div></div>
<div class="bank-row" style="margin-top:8px"><span>a.n.</span><strong>PT BioTeknologi Nasional</strong></div>
<div class="bank-row" style="background:rgba(245,158,11,.1);padding:8px;border-radius:6px;margin-top:8px">
<span>Jumlah Transfer Tepat:</span>
<div><strong style="color:var(--c-amber)">Rp <%= Number(order.grand_total).toLocaleString('id-ID') %></strong><button type="button" class="copy-btn" onclick="copyText('<%= order.grand_total %>')">Salin</button></div>
</div>
</div>
<% } else { %>
<div class="qris-box"><div class="qris-img"><i class="fas fa-qrcode"></i></div><p style="font-size:13px;color:var(--c-text3)">Scan QR Code atau buka aplikasi dompet digital Anda</p><p style="font-weight:700;font-size:18px;color:var(--c-primary);margin-top:8px">Rp <%= Number(order.grand_total).toLocaleString('id-ID') %></p></div>
<% } %>
</div></div>

<div class="card"><div class="card-body">
<h3 style="margin-bottom:16px"><i class="fas fa-upload" style="color:var(--c-primary-l)"></i> Upload Bukti Pembayaran</h3>
<p style="font-size:14px;color:var(--c-text3);margin-bottom:20px">Upload screenshot atau foto bukti transfer/pembayaran Anda (JPG, PNG, PDF, max 5MB)</p>
<div class="upload-zone" id="uploadZone" onclick="document.getElementById('proofFile').click()">
<i class="fas fa-cloud-upload-alt" style="font-size:40px;color:var(--c-text3);display:block;margin-bottom:12px"></i>
<p>Klik atau drag & drop file bukti pembayaran</p>
<p style="font-size:12px">JPG, PNG, PDF — Maksimal 5MB</p>
</div>
<input type="file" id="proofFile" accept=".jpg,.jpeg,.png,.pdf" style="display:none" onchange="previewFile(this)">
<img id="previewImg" class="upload-preview" style="display:none">
<div id="uploadStatus" style="margin-top:16px"></div>
<button class="btn btn-primary btn-block btn-lg" style="margin-top:16px" onclick="uploadProof()"><i class="fas fa-check-circle"></i> Konfirmasi Pembayaran</button>
</div></div>
<% } %>
</div></section>
<script>
function previewFile(input){const file=input.files[0];if(!file)return;const img=document.getElementById('previewImg');if(file.type.startsWith('image/')){const reader=new FileReader();reader.onload=e=>{img.src=e.target.result;img.style.display='block';};reader.readAsDataURL(file);}else{img.style.display='none';document.getElementById('uploadStatus').innerHTML='<p style="color:var(--c-primary-l)"><i class="fas fa-file-pdf"></i> File PDF dipilih: '+file.name+'</p>';}}
async function uploadProof(){const file=document.getElementById('proofFile').files[0];if(!file){showToast('Pilih file bukti pembayaran terlebih dahulu','error');return;}const formData=new FormData();formData.append('proof',file);const btn=event.target;btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Mengupload...';try{const r=await fetch('/shop/payment/<%= order.id %>/upload',{method:'POST',body:formData});const d=await r.json();if(d.success){showToast('Bukti pembayaran berhasil dikirim!');setTimeout(()=>location.reload(),2000);}else{showToast(d.message||'Upload gagal','error');btn.disabled=false;btn.innerHTML='<i class="fas fa-check-circle"></i> Konfirmasi Pembayaran';}}catch(e){showToast('Terjadi kesalahan','error');btn.disabled=false;btn.innerHTML='<i class="fas fa-check-circle"></i> Konfirmasi Pembayaran';}}
function copyText(t){navigator.clipboard.writeText(t).then(()=>showToast('Disalin!'));}
// Countdown 24 hours
const el=document.getElementById('countdown');if(el){let s=86400;setInterval(()=>{s--;const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=s%60;el.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');if(s<=0)el.textContent='KADALUARSA';},1000);}
// Drag drop
const zone=document.getElementById('uploadZone');if(zone){zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('dragover');});zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('dragover');document.getElementById('proofFile').files=e.dataTransfer.files;previewFile(document.getElementById('proofFile'));});}
</script>
<%- include('../../partials/footer') %>
