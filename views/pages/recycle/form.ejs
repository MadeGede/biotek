<%- include('../../partials/header') %>
<div class="page-header"><h1>Ajukan Daur Ulang</h1><p>Isi formulir berikut untuk pengajuan pickup limbah Anda</p><div class="breadcrumb"><a href="/">Home</a><span>›</span><a href="/daur-ulang">Daur Ulang</a><span>›</span><span>Formulir</span></div></div>
<section class="section-sm"><div class="container" style="max-width:720px">
<div style="background:linear-gradient(135deg,var(--c-primary),var(--c-primary-l));border-radius:var(--r-lg);padding:16px 20px;display:flex;align-items:center;gap:12px;margin-bottom:24px;color:#fff">
<i class="fas fa-star" style="color:var(--c-accent);font-size:20px"></i>
<span>Setiap pengajuan mendapat <strong>50 poin reward</strong> yang bisa ditukar diskon belanja!</span>
</div>
<div class="card"><div class="card-body" style="padding:32px">
<form action="/daur-ulang/form" method="POST" enctype="multipart/form-data">
<h4 style="margin-bottom:20px"><i class="fas fa-user" style="color:var(--c-primary-l)"></i> Data Pengaju</h4>
<div class="grid-2">
<div class="form-group"><label class="form-label">Nama Lengkap *</label><input name="name" class="form-control" placeholder="Nama Anda" value="<%= user?.name||'' %>" required></div>
<div class="form-group"><label class="form-label">No. HP *</label><input name="phone" class="form-control" placeholder="08xxxxxxxxxx" required></div>
</div>
<div class="form-group"><label class="form-label">Alamat Lengkap *</label><textarea name="address" class="form-control" rows="3" placeholder="Jl. Nama Jalan No. X, RT/RW, Kelurahan, Kecamatan, Kota" required></textarea></div>

<h4 style="margin:24px 0 20px"><i class="fas fa-recycle" style="color:var(--c-primary-l)"></i> Informasi Limbah</h4>
<div class="form-group"><label class="form-label">Jenis Limbah *</label>
<div class="waste-type-grid">
<% [['Kertas & Kardus','📄'],['Plastik','🧴'],['Logam & Elektronik','🔩'],['Kaca','🍶'],['Organik','🌱'],['Lainnya','♻️']].forEach(([type,icon])=>{ %>
<div class="waste-type-card" onclick="selectWaste(this,'<%= type %>')"><div class="icon"><%= icon %></div><h4><%= type %></h4></div>
<% }) %>
</div>
<input type="hidden" name="waste_type" id="wasteTypeInput" required>
</div>
<div class="grid-2">
<div class="form-group"><label class="form-label">Perkiraan Berat (kg)</label><input name="waste_weight" type="number" step="0.1" min="0" class="form-control" placeholder="Contoh: 5.5"></div>
<div class="form-group"><label class="form-label">Deskripsi Limbah</label><input name="description" class="form-control" placeholder="Kondisi & detail tambahan limbah"></div>
</div>
<div class="form-group"><label class="form-label">Foto Limbah (Opsional)</label>
<div class="upload-zone" onclick="document.getElementById('wastePhoto').click()" id="wasteZone">
<i class="fas fa-camera" style="font-size:28px;color:var(--c-text3);display:block;margin-bottom:8px"></i>
<p>Klik atau drag & drop foto limbah</p>
<p style="font-size:12px;color:var(--c-text3)">JPG, PNG, WEBP — Maks. 5MB</p>
</div>
<input type="file" id="wastePhoto" name="photo" accept=".jpg,.jpeg,.png,.webp" style="display:none" onchange="previewWaste(this)">
<img id="wastePreview" class="upload-preview" style="display:none">
</div>

<h4 style="margin:24px 0 20px"><i class="fas fa-calendar-alt" style="color:var(--c-primary-l)"></i> Jadwal Pickup</h4>
<div class="grid-2">
<div class="form-group"><label class="form-label">Tanggal Pickup *</label><input name="pickup_date" type="date" class="form-control" min="<%= new Date(Date.now()+86400000).toISOString().split('T')[0] %>" required></div>
<div class="form-group"><label class="form-label">Waktu Pickup *</label>
<select name="pickup_time" class="form-control" required>
<option value="">-- Pilih Waktu --</option>
<option value="08:00 - 10:00">08:00 - 10:00 WIB</option>
<option value="10:00 - 12:00">10:00 - 12:00 WIB</option>
<option value="13:00 - 15:00">13:00 - 15:00 WIB</option>
<option value="15:00 - 17:00">15:00 - 17:00 WIB</option>
</select>
</div>
</div>

<div style="background:var(--c-bg2);border-radius:var(--r-md);padding:16px;margin-bottom:24px;font-size:13px;color:var(--c-text3)">
<p><i class="fas fa-info-circle" style="color:var(--c-primary-l)"></i> <strong>Catatan:</strong> Tim kami akan menghubungi Anda H-1 untuk konfirmasi. Pastikan nomor HP aktif.</p>
</div>
<button type="submit" class="btn btn-primary btn-block btn-lg"><i class="fas fa-check-circle"></i> Kirim Pengajuan & Dapatkan 50 Poin</button>
</form></div></div>
</div></section>
<script>
function selectWaste(el,type){document.querySelectorAll('.waste-type-card').forEach(c=>c.classList.remove('selected'));el.classList.add('selected');document.getElementById('wasteTypeInput').value=type;}
function previewWaste(input){const file=input.files[0];if(!file)return;const reader=new FileReader();reader.onload=e=>{const img=document.getElementById('wastePreview');img.src=e.target.result;img.style.display='block';};reader.readAsDataURL(file);}
const zone=document.getElementById('wasteZone');if(zone){zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('dragover');});zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('dragover');document.getElementById('wastePhoto').files=e.dataTransfer.files;previewWaste(document.getElementById('wastePhoto'));});}
</script>
<%- include('../../partials/footer') %>
