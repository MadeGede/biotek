<div class="chatbot-wrapper">
  <div class="chatbot-window" id="chatbotWindow">
    <div class="chatbot-header">
      <div class="chatbot-avatar"><i class="fas fa-leaf"></i></div>
      <div><strong>BioBot</strong><small>Asisten Virtual • Online</small></div>
      <button class="chatbot-close" id="chatbotClose"><i class="fas fa-times"></i></button>
    </div>
    <div class="chatbot-messages" id="chatMessages">
      <div class="chat-msg bot"><div class="chat-bubble">Halo! Saya <strong>BioBot</strong> 🌱 Asisten virtual PT BioTeknologi Nasional. Ada yang bisa saya bantu hari ini?</div></div>
      <div class="chat-quickreply">
        <button onclick="sendQuick('Info produk')">Info produk</button>
        <button onclick="sendQuick('Cara daur ulang')">Cara daur ulang</button>
        <button onclick="sendQuick('Info poin')">Info poin</button>
        <button onclick="sendQuick('Cara pembayaran')">Pembayaran</button>
      </div>
    </div>
    <div class="chatbot-input">
      <input type="text" id="chatInput" placeholder="Ketik pesan..." maxlength="200">
      <button id="chatSend"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>
  <button class="chatbot-toggle" id="chatbotToggle" title="Chat dengan BioBot">
    <i class="fas fa-comments" id="chatIcon"></i>
    <i class="fas fa-times" id="chatCloseIcon" style="display:none"></i>
    <span class="chat-dot"></span>
  </button>
</div>

